@startuml
title Causal Self-Attention

skinparam shadowing false
skinparam roundcorner 8
skinparam defaultFontName SansSerif
skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor #333333
}

rectangle "x\n(B, T, 384)" as input
rectangle "c_attn\none Linear -> split into Q, K, V" as cattn
rectangle "split into 6 heads\neach head: (B, T, 64)" as split
rectangle "Q @ K^T / sqrt(64)\nsimilarity scores" as scores
rectangle "mask future positions\ncausal: can only look back" as mask
rectangle "softmax -> weights" as softmax
rectangle "weights @ V\nweighted combination" as values
rectangle "head1  head2  ...  head6" as heads
rectangle "concatenate all heads" as concat
rectangle "c_proj\nproject back to 384 dims" as cproj
rectangle "output\n(B, T, 384)" as output

input -down-> cattn
cattn -down-> split
split -down-> scores
scores -down-> mask
mask -down-> softmax
softmax -down-> values
values -down-> heads
heads -down-> concat
concat -down-> cproj
cproj -down-> output
@enduml
